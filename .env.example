# ================================================================
# DikDur — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp .env adıyla kaydedin, ardından doldurun.
# ================================================================

# ── Veritabanı ─────────────────────────────────────────────────
POSTGRES_DB=dikdur_db
POSTGRES_USER=dikdur_user
# Güçlü, rastgele bir şifre kullanın (örn: openssl rand -base64 32)
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_YAZ

# ── JWT ────────────────────────────────────────────────────────
# En az 64 karakterlik rastgele string (örn: openssl rand -base64 64)
JWT_SECRET=BURAYA_COK_UZUN_VE_RASTGELE_BIR_STRING_YAZ
JWT_EXPIRES_IN=7d

# ── AI Servisleri ───────────────────────────────────────────────
# Groq (ücretsiz, önerilen): https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (opsiyonel, Groq yoksa kullanılır)
# OPENAI_API_KEY=sk-XXXX
# OPENAI_MODEL=gpt-4o-mini

# Ollama (yerel — Docker içinde otomatik)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# Fine-tuned model adı — Colab'da eğitip Ollama'ya yükledikten sonra aktif edin
# OLLAMA_FT_MODEL=dikdur-ft

# ── Admin Hesabı ────────────────────────────────────────────────
ADMIN_EMAIL=admin@dikdur.com
# Güçlü bir şifre kullanın — özel karakter, büyük harf, rakam içermeli
ADMIN_PASSWORD=BURAYA_ADMIN_SIFRESI_YAZ

# ── Domain & CORS ───────────────────────────────────────────────
# Canlı domain adresiniz (HTTPS dahil, sonda / olmadan)
APP_URL=https://www.dikdur.com
# Birden fazla domain için virgülle ayırın: https://dikdur.com,https://www.dikdur.com
CORS_ORIGIN=https://www.dikdur.com

# ── E-posta (Şifre Sıfırlama) ───────────────────────────────────
# Gmail için "Uygulama Şifresi" oluşturun (2FA aktifken):
# Google Hesabım → Güvenlik → Uygulama Şifreleri
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sizin@gmail.com
SMTP_PASS=GMAIL_UYGULAMA_SIFRESI
SMTP_FROM=DikDur <noreply@dikdur.com>

# ── Geliştirme Ortamı (production'da kullanmayın) ───────────────
# Geliştirmede SMTP yoksa token konsola yazılır (güvensiz!)
# SMTP_HOST değerini boş bırakırsanız bu mod devreye girer.
